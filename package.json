{
  "name": "sist-etiquetas",
  "version": "1.0.0",
  "main": "electron.js",
  "scripts": {
    "start": ".\\node_modules\\electron\\dist\\electron.exe .\\electron.js",
    "postinstall": "electron-rebuild -f -w sqlite3",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.sistetiquetas.app",
    "productName": "Sist. Etiquetas",
    "asar": true,
    "files": [
      "electron.js",
      "server.js",
      "frontend/**/*",
      "backend/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sqlite3/build",
        "to": "node_modules/sqlite3/build"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9"
  }
}
